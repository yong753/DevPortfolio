---
interface Props {
    label: string;
}

const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
    .tag{
        display: inline-block;
        padding: 2px 10px;
        background: var(--accent-light);
        color: var(--accent);
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
    }
</style>

---
import TechTag from "./TechTag.astro";

interface OverviewItem {
    label: string;
    value: string;
}

interface KeyFeature {
    title: string;
    description: string;
    items: string[];
}

interface Props {
    title: string;
    description: string;
    thumbnail: string;
    techStack: string[];
    features: string[];
    highlights?: string[];
    gallery: string[];
    githubUrl?: string;
    liveUrl?: string;
    overview?: OverviewItem[];
    role?: string[];
    keyFeatures?: KeyFeature[];
    results?: string[];
}

const { title, description, thumbnail, techStack, features, highlights, gallery, githubUrl, liveUrl, overview, role, keyFeatures, results } = Astro.props;
const hasStructuredContent = overview || role || keyFeatures || results;

function isVideo(src: string): boolean {
    return /\.(mp4|webm|ogg)(\?.*)?$/i.test(src);
}

---

<div class="detail">
    {gallery && gallery.length > 0 && (
        <div class={"gallery"}>
            {gallery.map((src, i) => 
            isVideo(src)
            ? <video src={src} controls preload="auto" aria-label={`${title} video ${i + 1}`} />
            : <img src={src} alt={`${title} screenshot ${i + 1}`} />
        )}
        </div>
    )}
    <div class="info">
        <h1>{title}</h1>
        <p class="summary">{description}</p>
        {hasStructuredContent ? (
            <div class="structured-sections">
                {overview && overview.length > 0 && (
                    <section class="content-section">
                        <h2>프로젝트 개요</h2>
                        <dl class="overview-grid">
                            {overview.map(item => (
                                <div class="overview-item">
                                    <dt>{item.label}</dt>
                                    <dd>{item.value}</dd>
                                </div>
                            ))}
                        </dl>
                    </section>
                )}

                {role && role.length > 0 && (
                    <section class="content-section">
                        <h2>담당 역할</h2>
                        <ul class="simple-list">
                            {role.map(item => <li>{item}</li>)}
                        </ul>
                    </section>
                )}

                {keyFeatures && keyFeatures.length > 0 && (
                    <section class="content-section">
                        <h2>주요 기능</h2>
                        <div class="feature-grid">
                            {keyFeatures.map(feature => (
                                <article class="feature-card">
                                    <h3>{feature.title}</h3>
                                    <p>{feature.description}</p>
                                    <ul>
                                        {feature.items.map(item => <li>{item}</li>)}
                                    </ul>
                                </article>
                            ))}
                        </div>
                    </section>
                )}

                {results && results.length > 0 && (
                    <section class="content-section">
                        <h2>성과</h2>
                        <ul class="simple-list result-list">
                            {results.map(item => <li>{item}</li>)}
                        </ul>
                    </section>
                )}
            </div>
        ) : (
            <div class="sections">
                <div class="section">
                    <h2>주요 기능</h2>
                    <ul>
                        {features.map(f => <li>{f}</li>)}
                    </ul>
                </div>
                {highlights && highlights.length > 0 && (
                    <div class="section">
                        <h2>특징</h2>
                        <ul>
                            {highlights.map(h => <li>{h}</li>)}
                        </ul>
                    </div>
                )}
            </div>
        )}
        <div class="tags">
            {techStack.map(tech => <TechTag label={tech} />)}
        </div>
        <div class="links">
            {githubUrl && <a href={githubUrl} target="_blank">GitHub</a>}
            {liveUrl && <a href={liveUrl} target="_blank">Live Demo</a>}
        </div>
    </div>
</div>

<style>
    .thumbnail-wrap{
        width: 100%;
        height: 40vh;
        background: var(--bg-card);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 4px 0px;
    }

    .thumbnail-wrap img {
        height: 100%;
        object-fit: contain;
        border-radius: 8px;
        border: 2px solid var(--border);
    }

    .detail {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .gallery {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 0 var(--grid-gap);
        margin-top: 12px;
    }

    .gallery img {
        height: 40vh;
        width: auto;
        max-width: 50%;
        object-fit: contain;
        break-inside: avoid;
        margin-bottom: 12px;
        border-radius: 8px;
        border: 2px solid var(--border);
        display: block;
    }

    .gallery video {
        height: 40vh;
        width: auto;
        max-width: 50%;
        object-fit: contain;
        /* break-inside: avoid; */
        border-radius: 8px;
        border: 2px solid var(--border);
        margin-bottom: 12px;
        background: var(--bg-card);
        /* display: block; */
    }

    .info {
        padding: var(--grid-gap);
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    h1 {
        font-size: 1.75rem;
    }

    .summary {
        color: var(--text-secondary);
        margin-top: 10px;
        line-height: var(--line-height);
        border-left: 3px solid var(--accent);
        padding-left: 12px;
    }

    .sections {
        margin-top: 20px;
    }

    .structured-sections {
        display: flex;
        flex-direction: column;
        gap: 28px;
        margin-top: 28px;
    }

    .content-section h2 {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--accent-light);
    }

    .overview-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        margin: 0;
    }

    .overview-item {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
    }

    .overview-item dt {
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .overview-item dd {
        color: var(--text-primary);
        font-size: 0.92rem;
        line-height: 1.55;
        margin: 0;
    }

    .simple-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .simple-list li {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 0.9rem;
        line-height: 1.5;
        padding: 10px 12px;
    }

    .result-list li {
        border-color: transparent;
        background: var(--accent-light);
        color: var(--accent);
        font-weight: 500;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .feature-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: var(--shadow);
        padding: 18px;
    }

    .feature-card h3 {
        color: var(--text-primary);
        font-size: 1rem;
        margin-bottom: 8px;
    }

    .feature-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.65;
    }

    .feature-card ul {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        list-style: none;
        padding: 0;
        margin: 14px 0 0;
    }

    .feature-card li {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--text-primary);
        font-size: 0.8rem;
        line-height: 1.4;
        padding: 5px 10px;
    }

    .section {
        margin-bottom: 20px;
    }

    .section h2 {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 2px solid var(--accent-light);
    }

    .section ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .section li {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 0.875rem;
        color: var(--text-primary);
        line-height: 1.4;
    }

    .section:first-child li {
        background: var(--accent-light);
        border-color: transparent;
        color: var(--accent);
        font-weight: 500;
    }

    .tags{
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 16px;
    }

    .links{
        display: flex;
        gap: 12px;
        margin-top: auto;
        padding-bottom: var(--grid-gap);
    }

    .links a {
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .links a:first-child {
        background: var(--accent);
        color: white;
    }

    .links a:last-child{
        border: 1px solid var(--border);
        color: var(--text-primary);
    }

    @media (max-width: 600px) {
        .gallery {
            columns: 1;
        }

        .gallery img,
        .gallery video {
            max-width: 100%;
        }

        .overview-grid,
        .simple-list,
        .feature-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

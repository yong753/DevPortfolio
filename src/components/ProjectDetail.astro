---
import TechTag from "./TechTag.astro";

interface Props {
    title: string;
    description: string;
    thumbnail: string;
    techStack: string[];
    gallery?: string[];
    githubUrl?: string;
    liveUrl?: string;
}

const { title, description, thumbnail, techStack, gallery, githubUrl, liveUrl } = Astro.props;
---

<div class="detail">
    <div class="thumbnail-wrap">
        <img src={thumbnail} alt={`screenshot of ${title}`} />
    </div>
    {gallery && gallery.length > 0 && (
        <h2>이미지</h2>
        <div class={"gallery"}>
            {gallery.map((src, i) => (
                <img src={src} alt={`${title} screenshot ${i + 1}`} />
            ))}
        </div>
    )}
    <div class="info">
        <h1>{title}</h1>
        <p class="description">{description}</p>
        <div class = "tags">
            {techStack.map(tech => <TechTag label={tech} />)}
        </div>
        <div class="links">
            {githubUrl && <a href={githubUrl} target="_blank">GitHub</a>}
            {liveUrl && <a href={liveUrl} target="_blank">Live Demo</a>}
        </div>
    </div>
</div>

<style>
    .thumbnail-wrap{
        width: 100%;
        height: 40vh;
        background: var(--bg-card);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 4px 0px;
    }

    .thumbnail-wrap img {
        /* width: 100%; */
        height: 100%;
        object-fit: contain;
        border-radius: 8px;
        border: 2px solid var(--border);
    }

    .detail {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .gallery {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 0 var(--grid-gap);
        margin-top: 12px;
    }

    .gallery img {
        height: 40vh;
        width: auto;
        max-width: 100%;
        object-fit: contain;
        break-inside: avoid;
        margin-bottom: 12px;
        border-radius: 8px;
        border: 2px solid var(--border);
        display: block;
    }

    .info {
        padding: var(--grid-gap);
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    h1 {
        font-size: 1.75rem;
    }

    .description{
        color: var(--text-secondary);
        margin-top: 8px;
        line-height: var(--line-height);
    }

    .tags{
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 16px;
    }

    .links{
        display: flex;
        gap: 12px;
        margin-top: auto;
        padding-bottom: var(--grid-gap);
    }

    .links a {
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .links a:first-child {
        background: var(--accent);
        color: white;
    }

    .links a:last-child{
        border: 1px solid var(--border);
        color: var(--text-primary);
    }

    @media (max-width: 600px) {
        .gallery {
            columns: 1;
        }
    }
</style>
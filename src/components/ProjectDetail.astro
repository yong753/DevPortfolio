---
import TechTag from "./TechTag.astro";

interface Props {
    title: string;
    description: string;
    thumbnail: string;
    techStack: string[];
    features: string[];
    highlights?: string[];
    gallery: string[];
    githubUrl?: string;
    liveUrl?: string;
}

const { title, description, thumbnail, techStack, features, highlights, gallery, githubUrl, liveUrl } = Astro.props;
---

<div class="detail">
    {gallery && gallery.length > 0 && (
        <div class={"gallery"}>
            {gallery.map((src, i) => (
                <img src={src} alt={`${title} screenshot ${i + 1}`} />
            ))}
        </div>
    )}
    <div class="info">
        <h1>{title}</h1>
        <p class="summary">{description}</p>
        <div class="sections">
            <div class="section">
                <h2>주요 기능</h2>
                <ul>
                    {features.map(f => <li>{f}</li>)}
                </ul>
            </div>
            {highlights && highlights.length > 0 && (
                <div class="section">
                    <h2>특징</h2>
                    <ul>
                        {highlights.map(h => <li>{h}</li>)}
                    </ul>
                </div>
            )}
        </div>
        <div class="tags">
            {techStack.map(tech => <TechTag label={tech} />)}
        </div>
        <div class="links">
            {githubUrl && <a href={githubUrl} target="_blank">GitHub</a>}
            {liveUrl && <a href={liveUrl} target="_blank">Live Demo</a>}
        </div>
    </div>
</div>

<style>
    .thumbnail-wrap{
        width: 100%;
        height: 40vh;
        background: var(--bg-card);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 4px 0px;
    }

    .thumbnail-wrap img {
        height: 100%;
        object-fit: contain;
        border-radius: 8px;
        border: 2px solid var(--border);
    }

    .detail {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .gallery {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 0 var(--grid-gap);
        margin-top: 12px;
    }

    .gallery img {
        height: 40vh;
        width: auto;
        max-width: 50%;
        object-fit: contain;
        break-inside: avoid;
        margin-bottom: 12px;
        border-radius: 8px;
        border: 2px solid var(--border);
        display: block;
    }

    .info {
        padding: var(--grid-gap);
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    h1 {
        font-size: 1.75rem;
    }

    .summary {
        color: var(--text-secondary);
        margin-top: 10px;
        line-height: var(--line-height);
        border-left: 3px solid var(--accent);
        padding-left: 12px;
    }

    .sections {
        margin-top: 20px;
    }

    .section {
        margin-bottom: 20px;
    }

    .section h2 {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 2px solid var(--accent-light);
    }

    .section ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .section li {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 0.875rem;
        color: var(--text-primary);
        line-height: 1.4;
    }

    .section:first-child li {
        background: var(--accent-light);
        border-color: transparent;
        color: var(--accent);
        font-weight: 500;
    }

    .tags{
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 16px;
    }

    .links{
        display: flex;
        gap: 12px;
        margin-top: auto;
        padding-bottom: var(--grid-gap);
    }

    .links a {
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        font-size: 0.875rem;
    }

    .links a:first-child {
        background: var(--accent);
        color: white;
    }

    .links a:last-child{
        border: 1px solid var(--border);
        color: var(--text-primary);
    }

    @media (max-width: 600px) {
        .gallery {
            columns: 1;
        }
    }
</style>
